# Azure App registration -> Application (client) ID
ONENOTE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Use "common" for both personal Microsoft accounts and work/school accounts.
# Use your tenant id if you want to restrict to one tenant.
ONENOTE_TENANT_ID=common

# Delegated read-only permissions used by this server.
ONENOTE_SCOPES=Notes.Read User.Read offline_access

# Optional. By default: ~/.codex-onenote-mcp/msal-cache.json
# ONENOTE_TOKEN_CACHE=/absolute/path/msal-cache.json

# Optional. By default: ~/.codex-onenote-mcp/onenote-cache.sqlite
# ONENOTE_CACHE_DB=/absolute/path/onenote-cache.sqlite

# First sync can be heavy. Keep low to avoid Microsoft Graph throttling.
ONENOTE_SYNC_CONCURRENCY=2

# Store raw page HTML too. Text is always cached. For thousands of large pages, keep false unless needed.
ONENOTE_CACHE_INCLUDE_HTML=false

# Retry settings for Graph throttling/transient errors.
ONENOTE_GRAPH_MAX_ATTEMPTS=10
ONENOTE_GRAPH_MAX_THROTTLE_ATTEMPTS=100

# Minimum delay between starts of Graph requests. Shared by all concurrent workers.
ONENOTE_GRAPH_MIN_INTERVAL_MS=750

# Optional BibleNote integration. When enabled, sync sends cached page content to a local
# BibleNote API and stores paragraph-level Bible references in SQLite.
ONENOTE_BIBLE_PARSE_ENABLED=false
BIBLENOTE_API_URL=http://127.0.0.1:5000
BIBLENOTE_MODULE=rst
BIBLENOTE_USE_COMMA_DELIMITER=true
BIBLENOTE_API_TIMEOUT_MS=30000
